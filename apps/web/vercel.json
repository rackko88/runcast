{
  "rewrites": [
    {
      "source": "/hrfco-api/:path*",
      "destination": "https://api.hrfco.go.kr/:path*"
    },
    {
      "source": "/kma-api/:path*",
      "destination": "https://apihub.kma.go.kr/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
